---
import { Image } from "astro:assets";
import siteConfig from "../site.config";

type SiteIdentityProps = {
  logoWidth?: number;
  logoHeight?: number;
  loading?: "eager" | "lazy";
  textSize?: "text-base" | "text-xl";
  class?: string;
};

const {
  logoWidth = 50,
  logoHeight = 50,
  loading = "eager",
  textSize = "text-base",
  class: customClass,
}: SiteIdentityProps = Astro.props;
---

<div class:list={["flex items-center gap-2", customClass]}>
 <Image
src="/tristan-dumain-logo.png"
    alt="Logo"
    width={logoWidth}
    height={logoHeight}
    loading={loading}
    class="dark:hidden" 
  />


  <Image
    src="/tristan-dumain-logo-dark.png"
     alt="Logo"
    width={logoWidth}
    height={logoHeight}
    loading={loading}
    class="hidden dark:block" 
  />
  <span class:list={["sigmar-ff", textSize]}>{siteConfig.title}</span>
</div>
